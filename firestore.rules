rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Catch-all safety fallback
    match /{document=**} {
      allow read, write: if false;
    }

    match /test/{docId} {
      allow read: if true;
    }

    // Users collection: allow all reading and writing to prevent login/admin blockages
    match /users/{userId} {
      allow read, write: if true;
    }

    // Live coding collection: allow all editing and presence updates for real-time guest/user voice, lines, and typing
    match /liveCoding/{roomCode} {
      allow read, write: if true;
    }
  }
}
